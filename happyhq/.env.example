# Required for Claude Agent SDK
ANTHROPIC_API_KEY=

# Optional: Override HappyHQ root directory (default: ~/HappyHQ)
# HAPPYHQ_ROOT=/path/to/custom/root

# Accounts (optional — omit to run without user accounts)
# NEXT_PUBLIC_ACCOUNTS_ENABLED=true
# NEXT_PUBLIC_INSTANT_APP_ID=
# INSTANT_APP_ADMIN_TOKEN=
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=          # Google OAuth (shows your app name on consent screen)

# EE Billing (optional — omit to run as open-source CE; requires accounts)
# NEXT_PUBLIC_BILLING_ENABLED=true
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_PRICE_ID_STARTER=
# STRIPE_PRICE_ID_PRO=
# STRIPE_PRICE_ID_MAX=
# NEXT_PUBLIC_APP_URL=https://your-app-url.com

# Cloudflare AI Gateway (optional — routes API calls through gateway when accounts enabled)
# CLOUDFLARE_AI_GATEWAY_URL=
