{
  "name": "happyhq",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "./scripts/check-deps.sh && turbo run build",
    "dev": "./scripts/check-deps.sh && turbo run dev",
    "lint": "turbo run lint",
    "test": "./scripts/check-deps.sh && turbo run test",
    "test:watch": "turbo run test:watch",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/yargs": "^17.0.32",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.5.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.22.0",
    "turbo": "^2.9.12",
    "typescript": "6.0.3",
    "yargs": "^18.0.0"
  },
  "packageManager": "pnpm@10.2.1",
  "engines": {
    "node": ">=20.9"
  },
  "dependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "tailwindcss": "4.3.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "ip-address": "^10.1.1",
      "postcss": "^8.5.14",
      "vite": "^7.1.11"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  }
}
